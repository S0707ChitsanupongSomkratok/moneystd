<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ใบสำคัญรับเงิน</title>
<link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Sarabun', sans-serif;
    background: #e8e8e8;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    min-height: 100vh;
    padding: 30px 20px;
  }

  .page-wrapper {
    background: white;
    width: 210mm;
    min-height: 297mm;
    padding: 20mm 20mm 15mm 20mm;
    box-shadow: 0 4px 24px rgba(0,0,0,0.18);
    position: relative;
  }

  /* Doc number top right */
  .doc-number {
    position: absolute;
    top: 15mm;
    right: 20mm;
    font-size: 13px;
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .doc-number label { font-weight: 400; }
  .doc-number input {
    border: none;
    border-bottom: 1px solid #333;
    width: 120px;
    font-family: 'Sarabun', sans-serif;
    font-size: 13px;
    outline: none;
    padding: 0 4px;
    background: transparent;
  }

  /* Title */
  .title-section {
    text-align: center;
    margin-bottom: 6px;
    margin-top: 8mm;
  }
  .title-main {
    font-size: 20px;
    font-weight: 600;
    letter-spacing: 0.5px;
  }
  .title-sub {
    font-size: 14px;
    font-weight: 400;
    margin-top: 2px;
  }

  /* Date row */
  .date-row {
    text-align: center;
    margin: 8px 0 14px 0;
    font-size: 13px;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 6px;
  }
  .date-row input {
    border: none;
    border-bottom: 1px solid #333;
    width: 220px;
    font-family: 'Sarabun', sans-serif;
    font-size: 13px;
    outline: none;
    text-align: center;
    background: transparent;
  }

  /* Info rows */
  .info-section { margin-bottom: 10px; }
  .info-row {
    display: flex;
    align-items: flex-end;
    gap: 4px;
    margin-bottom: 5px;
    font-size: 13px;
  }
  .info-row label { white-space: nowrap; font-weight: 400; min-width: fit-content; }
  .info-row input {
    flex: 1;
    border: none;
    border-bottom: 1px solid #333;
    font-family: 'Sarabun', sans-serif;
    font-size: 13px;
    outline: none;
    background: transparent;
    padding: 0 4px;
  }
  .info-row .suffix { white-space: nowrap; }

  /* Table */
  .items-table {
    width: 100%;
    border-collapse: collapse;
    margin: 10px 0 16px 0;
    font-size: 13px;
  }
  .items-table th, .items-table td {
    border: 1px solid #333;
    padding: 5px 8px;
    text-align: center;
  }
  .items-table th {
    background: #f5f5f5;
    font-weight: 600;
    font-size: 13px;
  }
  .items-table td.item-name { text-align: left; }
  .items-table td.amount, .items-table td.note { text-align: left; }
  .items-table td input {
    width: 100%;
    border: none;
    font-family: 'Sarabun', sans-serif;
    font-size: 13px;
    outline: none;
    background: transparent;
    text-align: inherit;
    padding: 1px 0;
  }
  .items-table .col-no { width: 40px; }
  .items-table .col-item { width: auto; }
  .items-table .col-amount { width: 120px; }
  .items-table .col-note { width: 160px; }

  /* Total row */
  .total-row td {
    font-weight: 600;
  }
  .total-label { text-align: center !important; }
  .total-status {
    display: flex;
    align-items: center;
    gap: 4px;
    font-weight: 400;
    font-size: 12.5px;
  }
  .total-status input {
    flex: 1;
  }

  /* Bottom section: ตัวหนังสือ + signatures aligned in same grid */
  .bottom-section {
    margin-top: 10px;
    display: flex;
    flex-direction: column;
    gap: 22px;
    align-items: flex-end;
  }
  .bottom-row {
    display: flex;
    align-items: flex-start;
    gap: 0;
    font-size: 13px;
    width: 60%;
  }
  /* Left label column — fixed width so all rows align */
  .bottom-row .b-label {
    white-space: nowrap;
    min-width: 72px;
    padding-top: 2px;
  }
  /* Center input block */
  .bottom-row .b-center {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
  }
  .bottom-row .b-center .line-input {
    border: none;
    border-bottom: 1px solid #333;
    width: 100%;
    font-family: 'Sarabun', sans-serif;
    font-size: 13px;
    outline: none;
    text-align: center;
    background: transparent;
    padding: 1px 4px;
  }
  .bottom-row .b-center .paren-row {
    display: flex;
    align-items: center;
    gap: 3px;
    width: 100%;
    justify-content: center;
  }
  .bottom-row .b-center .paren-row input {
    border: none;
    border-bottom: 1px solid #333;
    width: 80%;
    font-family: 'Sarabun', sans-serif;
    font-size: 13px;
    outline: none;
    text-align: center;
    background: transparent;
  }
  .bottom-row .b-center .static-name {
    font-size: 13px;
  }
  .bottom-row .b-center .static-role {
    font-size: 13px;
    font-weight: 500;
  }
  /* Right role label */
  .bottom-row .b-role {
    white-space: nowrap;
    min-width: 72px;
    text-align: right;
    padding-top: 2px;
  }

  /* Footer note */
  .footer-note {
    margin-top: 30px;
    font-size: 12px;
    border-top: 1px solid #aaa;
    padding-top: 8px;
  }
  .footer-note .note-title { font-weight: 600; }

  /* Print button */
  .print-btn {
    position: fixed;
    bottom: 24px;
    right: 24px;
    background: #2c2c2c;
    color: white;
    border: none;
    padding: 10px 22px;
    font-family: 'Sarabun', sans-serif;
    font-size: 14px;
    cursor: pointer;
    border-radius: 4px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
    transition: background 0.2s;
  }
  .print-btn:hover { background: #444; }

  @media print {
    body { background: white; padding: 0; }
    .page-wrapper { box-shadow: none; width: 100%; min-height: auto; }
    .print-btn { display: none; }
    input { border-bottom-color: #aaa !important; }
  }
</style>
</head>
<body>

<div class="page-wrapper">

  <!-- Doc number -->
  <div class="doc-number">
    <label>เลขที่</label>
    <input style="text-align: center; font-weight: bold;" readonly value="<%= std.no %>" type="text" placeholder="">
  </div>

  <!-- Title -->
  <div class="title-section">
    <div class="title-main">ใบสำคัญรับเงิน</div>
    <div class="title-sub">โรงเรียนอรพิมพ์วิทยา อำเภอครบุรี สังกัดองค์การบริหารส่วนจังหวัดนครราชสีมา</div>
  </div>

  <% const now = new Date();
    const d = String(now.getDate()).padStart(2, '0');
    const m = String(now.getMonth() + 1).padStart(2, '0');
    const y = now.getFullYear() + 543;
    const h = String(now.getHours()).padStart(2, '0');
    const min = String(now.getMinutes()).padStart(2, '0');
    
    const fullDate = `${d}-${m}-${y}-${h}:${min}`;
    const datere = `${y - 543}-${m}-${d}`; %>

  <!-- Date -->
  <div class="date-row">
    <span>วันที่</span>
    <input style="text-align: center; font-weight: bold;" readonly value="<%= datere %>" type="text" placeholder="วัน/เดือน/ปี">
  </div>

  <!-- Info rows -->
  <div class="info-section">
    <div class="info-row">
      <label>ได้รับเงินจาก</label>
      <input style="text-align: center; font-weight: bold;" readonly value="<%= std.name %>" type="text">
      <span class="suffix">ชั้น</span>
      <input style="text-align: center; font-weight: bold;" readonly value="ม.<%= std.classs %>" type="text" style="max-width:120px;">
    </div>
    <div class="info-row">
      <label>ที่อยู่</label>
      <input style="text-align: center; font-weight: bold;" readonly value="<%= std.homestd %>" type="text">
    </div>
    <div class="info-row">
      <label>โทร.</label>
      <input style="text-align: center; font-weight: bold;" readonly value="<%= std.tel %>" type="text">
    </div>
    <div class="info-row">
      <label>รายละเอียดดังรายการต่อไปนี้</label>
    </div>
  </div>

  <!-- Items table -->
  <table class="items-table">
    <thead>
      <tr>
        <th class="col-no">ที่</th>
        <th class="col-item">รายการ</th>
        <th class="col-amount">จำนวนเงิน</th>
        <th class="col-note">หมายเหตุ</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>1</td>
        <td class="item-name">ค่าประกันชีวิต</td>
        <td class="amount"><input style="text-align: center; font-weight: bold;" readonly value="<%= std.pk %>" type="text"></td>
        <td class="note"><input style="text-align: center; font-weight: bold;" type="text"></td>
      </tr>
      <tr>
        <td>2</td>
        <td class="item-name">ค่ากระเป๋านักเรียน</td>
        <td class="amount"><input style="text-align: center; font-weight: bold;" readonly value="<%= std.bag %>" type="text"></td>
        <td class="note"><input style="text-align: center; font-weight: bold;" type="text"></td>
      </tr>
      <tr>
        <td>3</td>
        <td class="item-name">ค่าเสื้อโปโล</td>
        <td class="amount"><input style="text-align: center; font-weight: bold;" readonly value="<%= std.polo %>" type="text"></td>
        <td class="note"><input style="text-align: center; font-weight: bold;" type="text"></td>
      </tr>
      <tr>
        <td>4</td>
        <td class="item-name">ค่าเสื้อกีฬา</td>
        <td class="amount"><input style="text-align: center; font-weight: bold;" readonly value="<%= std.sport %>" type="text"></td>
        <td class="note"><input style="text-align: center; font-weight: bold;" type="text"></td>
      </tr>
      <tr>
        <td>5</td>
        <td class="item-name">ค่าหุ้นสหกรณ์</td>
        <td class="amount"><input style="text-align: center; font-weight: bold;" readonly value="<%= std.market %>" type="text"></td>
        <td class="note"><input style="text-align: center; font-weight: bold;" type="text"></td>
      </tr>
      <tr>
        <td>6</td>
        <td class="item-name">ค่าเปิดบัญชีธนาคาร</td>
        <td class="amount"><input style="text-align: center; font-weight: bold;" readonly value="<%= std.bank %>" type="text"></td>
        <td class="note"><input style="text-align: center; font-weight: bold;" type="text"></td>
      </tr>
      <tr>
        <td>7</td>
        <td class="item-name">ค่าโปรแกรมสารสนเทศนักเรียนรายบุคคล</td>
        <td class="amount"><input style="text-align: center; font-weight: bold;" readonly value="<%= std.psis %>" type="text"></td>
        <td class="note"><input style="text-align: center; font-weight: bold;" type="text"></td>
      </tr>
      <tr>
        <td>8</td>
        <td class="item-name">ค่าประกันของเสียหาย</td>
        <td class="amount"><input style="text-align: center; font-weight: bold;" readonly value="<%= std.damage %>" type="text"></td>
        <td class="note"><input style="text-align: center; font-weight: bold;" type="text"></td>
      </tr>
      <tr class="total-row">
        <td colspan="2" class="total-label">รวมเป็นเงิน</td>
        <td class="amount"><input style="text-align: center; font-weight: bold;" readonly value="<%= std.moneysum %>" type="text"></td>
        <td class="note">
          <div class="total-status">
            สถานะจ่ายเงิน : <input style="text-align: center; font-weight: bold;" readonly value="<%= std.state %>" type="text">
          </div>
        </td>
      </tr>
    </tbody>
  </table>

  <!-- Bottom section: ตัวหนังสือ + ลายเซ็น เรียงตรงกัน -->
  <div class="bottom-section">

    <!-- ตัวหนังสือ -->
    <!-- <div class="bottom-row">
      <span class="b-label">ตัวหนังสือ </span>
      (________________________________________________________________________)
      <span class="b-role"></span>
    </div> -->

    <br>

    <!-- ลงชื่อผู้จ่ายเงิน -->
    <div class="bottom-row">
      <span class="b-label">ลงชื่อ</span>
      <div class="b-center">
        <input class="line-input" type="text">
        <div class="paren-row">
          (<input type="text">)
        </div>
      </div>
      <span class="b-role">ผู้จ่ายเงิน</span>
    </div>


    <br>
    <!-- ลงชื่อผู้รับเงิน -->
    <div class="bottom-row">
      <span class="b-label">ลงชื่อ</span>
      <div class="b-center">
        <input class="line-input" type="text">
        <div class="static-name">( นายกฤษฏ์ เตร่พิมาย )</div>
        <div class="static-role">เจ้าหน้าที่การเงิน</div>
      </div>
      <span class="b-role">ผู้รับเงิน</span>
    </div>

  </div>

  <!-- Footer note -->
  <div class="footer-note">
    <span class="note-title">*** หมายเหตุ ***</span><br>
    กรุณาเก็บใบสำคัญรับเงินไว้เป็นหลักฐานการรับอุปกรณ์รายการที่ 2 รายการที่ 3 และรายการที่ 4
  </div>

</div>

<button class="print-btn" onclick="window.print()">🖨️ พิมพ์</button>

</body>
</html>